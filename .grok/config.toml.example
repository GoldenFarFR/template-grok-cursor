# Copier vers ~/.grok/config.toml ou garder ici pour un projet spécifique.
# Ne jamais committer de tokens ou clés API.

[models]
default = "grok-build"

[ui]
permission_mode = "always-approve"

# Exemple MCP GitHub — remplacer le token par le vôtre
# [mcp_servers.github]
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-github"]
# enabled = true
#
# [mcp_servers.github.env]
# GITHUB_PERSONAL_ACCESS_TOKEN = "ghp_votre_token"